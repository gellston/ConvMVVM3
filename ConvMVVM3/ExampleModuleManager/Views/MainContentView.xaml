<UserControl x:Class="ExampleModuleManager.Views.MainContentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ExampleModuleManager.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             xmlns:convMVVM3="https://github.com/gellston/ConvMVVM3"
             convMVVM3:ViewModelLocator.AutoWireViewModel="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="50"></RowDefinition>
        </Grid.RowDefinitions>
        <ContentControl Grid.Row="0"
                        convMVVM3:RegionPlugin.RegionName="SubContent"></ContentControl>
        <UniformGrid Grid.Row="1"
                     Rows="1">
            <Button Content="AModule" Command="{Binding AModuleCommand}"></Button>
            <Button Content="BModule" Command="{Binding BModuleCommand}"></Button>
            <Button Content="CModule Init On Demand" Command="{Binding CModuleLoadCommand}"></Button>
        </UniformGrid>
    </Grid>
</UserControl>
